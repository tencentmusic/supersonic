# Environment variables — copy to `.env` (git-ignored) or export in your shell.
# Spring Boot reads these when set in the environment (IDE / systemd / docker-compose).
#
# Standalone dev: activate profile `dev` (default S2_ENV=dev) and set below as needed.
#
# Optional YAML: copy application-dev.yaml.example -> application-dev.yaml under
# launchers/standalone/src/main/resources/ (that file is git-ignored; git pull will not overwrite it).

# Database (example — match your local MySQL/Postgres)
# S2_DB_TYPE=h2
# S2_DB_HOST=127.0.0.1
# S2_DB_PORT=3306
# S2_DB_USER=root
# S2_DB_PASSWORD=
# S2_DB_DATABASE=supersonic

# AES encryption (required for some auth/tenant features — generate random values for real env)
S2_ENCRYPTION_KEY=
S2_ENCRYPTION_IV=

# Feishu / Lark (only if s2.feishu.enabled=true)
FEISHU_APP_ID=
FEISHU_APP_SECRET=
FEISHU_VERIFICATION_TOKEN=
FEISHU_ENCRYPT_KEY=

# LLM provider
# OPENAI_BASE_URL=https://api.openai.com/v1
# OPENAI_API_KEY=
# OPENAI_MODEL_NAME=gpt-4o
