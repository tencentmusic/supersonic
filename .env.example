# Environment variables for Docker Compose deployment.
# Copy to .env and fill in values. The .env file is git-ignored.
#
# For local Spring Boot development (non-Docker), use application-local.yaml instead.
# See application-dev.yaml for instructions.

# AES encryption (optional — built-in defaults are used when blank)
# S2_ENCRYPTION_KEY=your-aes-key
# S2_ENCRYPTION_IV=your-aes-iv

# Feishu / Lark integration
FEISHU_APP_ID=
FEISHU_APP_SECRET=
FEISHU_VERIFICATION_TOKEN=
FEISHU_ENCRYPT_KEY=

# LLM provider
# OPENAI_BASE_URL=https://api.openai.com/v1
# OPENAI_API_KEY=
# OPENAI_MODEL_NAME=gpt-4o
