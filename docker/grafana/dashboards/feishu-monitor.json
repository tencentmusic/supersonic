{
  "annotations": { "list": [] },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "id": 100,
      "title": "Overview",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "yellow", "value": 90 },
              { "color": "green", "value": 95 }
            ]
          },
          "unit": "percent",
          "min": 0, "max": 100
        }
      },
      "gridPos": { "h": 6, "w": 6, "x": 0, "y": 1 },
      "id": 1,
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] } },
      "title": "Query Success Rate",
      "type": "gauge",
      "targets": [
        {
          "expr": "sum(rate(feishu_query_duration_seconds_count{status=\"success\"}[5m])) / sum(rate(feishu_query_duration_seconds_count[5m])) * 100",
          "legendFormat": "success %"
        }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": { "unit": "ops", "color": { "mode": "palette-classic" } }
      },
      "gridPos": { "h": 6, "w": 6, "x": 6, "y": 1 },
      "id": 2,
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] } },
      "title": "Query Rate (QPS)",
      "type": "stat",
      "targets": [
        {
          "expr": "sum(rate(feishu_query_duration_seconds_count[1m]))",
          "legendFormat": "queries/s"
        }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 5 },
              { "color": "red", "value": 10 }
            ]
          }
        }
      },
      "gridPos": { "h": 6, "w": 6, "x": 12, "y": 1 },
      "id": 3,
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] } },
      "title": "Pending User Mappings",
      "type": "stat",
      "targets": [
        {
          "expr": "feishu_mapping_pending",
          "legendFormat": "pending"
        }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": { "unit": "short" }
      },
      "gridPos": { "h": 6, "w": 6, "x": 18, "y": 1 },
      "id": 4,
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] } },
      "title": "API Call Rate (per min)",
      "type": "stat",
      "targets": [
        {
          "expr": "sum(rate(feishu_api_call_total[1m])) * 60",
          "legendFormat": "calls/min"
        }
      ]
    },

    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 7 },
      "id": 101,
      "title": "Query Performance",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": { "unit": "s", "custom": { "drawStyle": "line", "fillOpacity": 10 } }
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "id": 5,
      "title": "Query Duration (P50 / P95 / P99)",
      "type": "timeseries",
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum(rate(feishu_query_duration_seconds_bucket[5m])) by (le))",
          "legendFormat": "P50"
        },
        {
          "expr": "histogram_quantile(0.95, sum(rate(feishu_query_duration_seconds_bucket[5m])) by (le))",
          "legendFormat": "P95"
        },
        {
          "expr": "histogram_quantile(0.99, sum(rate(feishu_query_duration_seconds_bucket[5m])) by (le))",
          "legendFormat": "P99"
        }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": { "unit": "ops", "custom": { "drawStyle": "bars", "fillOpacity": 80 } }
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "id": 6,
      "title": "Query Rate by Handler",
      "type": "timeseries",
      "targets": [
        {
          "expr": "sum(rate(feishu_query_duration_seconds_count[5m])) by (handler)",
          "legendFormat": "{{handler}}"
        }
      ]
    },

    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 16 },
      "id": 102,
      "title": "API Calls & Messages",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": { "unit": "ops", "custom": { "drawStyle": "line", "fillOpacity": 10 } }
      },
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 17 },
      "id": 7,
      "title": "Internal API Calls (by category)",
      "type": "timeseries",
      "targets": [
        {
          "expr": "sum(rate(feishu_api_call_total[5m])) by (api, status)",
          "legendFormat": "{{api}} [{{status}}]"
        }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": { "unit": "ops", "custom": { "drawStyle": "line", "fillOpacity": 10 } }
      },
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 17 },
      "id": 8,
      "title": "Message Sent (by type)",
      "type": "timeseries",
      "targets": [
        {
          "expr": "sum(rate(feishu_message_sent_total[5m])) by (type)",
          "legendFormat": "sent:{{type}}"
        },
        {
          "expr": "sum(rate(feishu_message_send_errors_total[5m])) by (type)",
          "legendFormat": "error:{{type}}"
        }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "red", "value": 1 }
            ]
          },
          "unit": "short"
        }
      },
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 17 },
      "id": 9,
      "title": "Token Refresh Failures",
      "type": "timeseries",
      "targets": [
        {
          "expr": "sum(rate(feishu_api_call_total{api=\"token\",status=\"error\"}[5m]))",
          "legendFormat": "token errors/s"
        }
      ]
    },

    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 25 },
      "id": 103,
      "title": "System Health",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": { "unit": "short", "custom": { "drawStyle": "line", "fillOpacity": 10 } }
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 26 },
      "id": 10,
      "title": "Rate Limit Hits",
      "type": "timeseries",
      "targets": [
        {
          "expr": "rate(feishu_rate_limit_hits_total[5m]) * 60",
          "legendFormat": "rate limited/min"
        }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "red", "value": 1 }
            ]
          },
          "custom": { "drawStyle": "line", "fillOpacity": 10 }
        }
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 26 },
      "id": 11,
      "title": "Executor Rejections (queue full)",
      "type": "timeseries",
      "targets": [
        {
          "expr": "rate(feishu_executor_rejections_total[5m]) * 60",
          "legendFormat": "rejections/min"
        }
      ]
    }
  ],
  "refresh": "10s",
  "schemaVersion": 39,
  "tags": ["feishu", "supersonic"],
  "templating": {
    "list": [
      {
        "current": { "selected": false, "text": "Prometheus", "value": "Prometheus" },
        "hide": 0,
        "includeAll": false,
        "name": "DS_PROMETHEUS",
        "options": [],
        "query": "prometheus",
        "type": "datasource"
      }
    ]
  },
  "time": { "from": "now-1h", "to": "now" },
  "timepicker": {},
  "timezone": "browser",
  "title": "Feishu Bot Monitor",
  "uid": "feishu-bot-monitor",
  "version": 1
}
