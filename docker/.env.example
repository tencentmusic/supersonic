# SuperSonic Docker Environment
# Copy to .env and fill in actual values: cp .env.example .env

# ── SuperSonic ────────────────────────────────────────────
SUPERSONIC_VERSION=latest

# ── Database (shared by MySQL container + SuperSonic) ─────
S2_DB_TYPE=mysql
S2_DB_DATABASE=supersonic
S2_DB_USER=supersonic_user
S2_DB_PASSWORD=supersonic_password
MYSQL_ROOT_PASSWORD=root_password
MYSQL_PORT=13306

# ── Redis (optional, for OAuth + Feishu cache) ───────────
S2_OAUTH_STORAGE_TYPE=redis
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DATABASE=0

# ── Feishu Bot ────────────────────────────────────────────
FEISHU_ENABLED=true
FEISHU_CONNECTION_MODE=ws
FEISHU_APP_ID=
FEISHU_APP_SECRET=
FEISHU_VERIFICATION_TOKEN=
FEISHU_ENCRYPT_KEY=
FEISHU_DEFAULT_AGENT_ID=1
FEISHU_CACHE_TYPE=caffeine

# ── Grafana ───────────────────────────────────────────────
GF_SECURITY_ADMIN_USER=admin
GF_SECURITY_ADMIN_PASSWORD=admin
